<UserControl
    x:Class="Uviewer.Controls.ExplorerSidebarControl"
    x:Name="SidebarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="using:Uviewer"
    xmlns:uc="using:Uviewer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="ToolbarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
    </UserControl.Resources>

            <!-- Sidebar Area -->
            <Grid x:Name="SidebarRoot" Background="{ThemeResource LayerFillColorDefaultBrush}" IsTabStop="False"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}" />
                        <Style TargetType="ToggleButton" BasedOn="{StaticResource ToolbarToggleButtonStyle}" />
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ToggleViewButton"
                            ToolTipService.ToolTip="썸네일 보기" Padding="6" Margin="0,0,8,0">
                        <Button.ContextFlyout>
                            <Flyout>
                                <StackPanel Width="260" Spacing="10" Padding="10">
                                    <TextBlock x:Name="ThumbnailSettingsTitleText" Text="{x:Bind app:Strings.ThumbnailSettingsTitle}" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <Grid>
                                        <TextBlock x:Name="ThumbnailSizeLabel" Text="{x:Bind app:Strings.ThumbnailSizeLabel}" FontSize="12" HorizontalAlignment="Left"/>
                                        <TextBlock x:Name="ThumbnailSizeValueText" Text="80" FontSize="12" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="ThumbnailSizeSlider" Minimum="64" Maximum="180" StepFrequency="4" Value="80"/>
                                    <CheckBox x:Name="FolderThumbnailsCheckBox" Content="{x:Bind app:Strings.ShowFolderThumbnailsLabel}"/>
                                </StackPanel>
                            </Flyout>
                        </Button.ContextFlyout>
                        <FontIcon Glyph="&#xE80A;" FontSize="14"/>
                    </Button>

                    <Button Grid.Column="1" x:Name="ParentFolderButton"
                            ToolTipService.ToolTip="상위 폴더로 가기(Backspace)" Padding="6" Margin="0,0,8,0">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    </Button>

                    <Button Grid.Column="2" x:Name="SidebarFavoritesButton" 
                            ToolTipService.ToolTip="즐겨찾기" Padding="6" Margin="0,0,8,0">
                        <FontIcon Glyph="&#xE734;" FontSize="14"/>
                        <Button.Flyout>
                            <Flyout x:Name="SidebarFavoritesFlyout" Placement="Bottom">
                                <StackPanel Width="400" MaxHeight="500">
                                    <StackPanel.Resources>
                                        <ResourceDictionary>
                                            <ResourceDictionary.ThemeDictionaries>
                                                <ResourceDictionary x:Key="Light">
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15000000"/>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#25000000"/>
                                                    <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#15000000"/>
                                                    <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="#25000000"/>
                                                </ResourceDictionary>
                                                <ResourceDictionary x:Key="Dark">
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15FFFFFF"/>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#25FFFFFF"/>
                                                    <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#15FFFFFF"/>
                                                    <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="#25FFFFFF"/>
                                                </ResourceDictionary>
                                            </ResourceDictionary.ThemeDictionaries>
                                        </ResourceDictionary>
                                    </StackPanel.Resources>
                                    <Button x:Name="SidebarAddToFavoritesButton" Content="➕ 즐겨찾기 추가" 
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Background="Transparent" BorderThickness="0">
                                        <Button.Resources>
                                            <ResourceDictionary>
                                                <ResourceDictionary.ThemeDictionaries>
                                                    <ResourceDictionary x:Key="Light">
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15000000"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#25000000"/>
                                                    </ResourceDictionary>
                                                    <ResourceDictionary x:Key="Dark">
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15FFFFFF"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#25FFFFFF"/>
                                                    </ResourceDictionary>
                                                </ResourceDictionary.ThemeDictionaries>
                                            </ResourceDictionary>
                                        </Button.Resources>
                                    </Button>
                                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>
                                    <Pivot x:Name="SidebarFavoritesPivot">
                                        <Pivot.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="14" FontWeight="SemiBold"/>
                                            </DataTemplate>
                                        </Pivot.HeaderTemplate>
                                        <PivotItem x:Name="SidebarFileFavoritesPivotItem" Header="{x:Bind app:Strings.FavoritesFiles}">
                                            <ScrollViewer MaxHeight="400" 
                                                         HorizontalScrollBarVisibility="Disabled" 
                                                         VerticalScrollBarVisibility="Auto">
                                                <uc:BookmarkListControl x:Name="SidebarFileFavoritesList"/>
                                            </ScrollViewer>
                                        </PivotItem>
                                        <PivotItem x:Name="SidebarFolderFavoritesPivotItem" Header="{x:Bind app:Strings.FavoritesFolders}">
                                            <ScrollViewer MaxHeight="400" 
                                                         HorizontalScrollBarVisibility="Disabled" 
                                                         VerticalScrollBarVisibility="Auto">
                                                <uc:BookmarkListControl x:Name="SidebarFolderFavoritesList"/>
                                            </ScrollViewer>
                                        </PivotItem>
                                    </Pivot>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    
                    <Button Grid.Column="3" x:Name="SidebarRecentButton" 
                            ToolTipService.ToolTip="최근 이미지" Padding="6" Margin="0,0,8,0">
                        <FontIcon Glyph="&#xE823;" FontSize="14"/>
                        <Button.Flyout>
                            <Flyout x:Name="SidebarRecentFlyout" Placement="Bottom">
                                <ScrollViewer MaxHeight="600" Width="400" 
                                             HorizontalScrollBarVisibility="Disabled" 
                                             VerticalScrollBarVisibility="Auto">
                                        <uc:BookmarkListControl x:Name="SidebarRecentList"/>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Grid.Column="4" x:Name="BrowseFolderButton" 
                            ToolTipService.ToolTip="폴더 열기" Padding="6" Margin="0,0,8,0">
                        <FontIcon Glyph="&#xED25;" FontSize="14"/>
                    </Button>

                    <Button Grid.Column="5" x:Name="SortByDateButton" Padding="6">
                        <FontIcon x:Name="SortIcon" Glyph="&#xE174;" FontSize="14"/>
                    </Button>

                    <Button Grid.Column="7" x:Name="WebDavButton"
                            ToolTipService.ToolTip="webdav 연결" Padding="6"
                            HorizontalAlignment="Right">
                        <FontIcon Glyph="&#xE774;" FontSize="14"/>
                        <Button.Flyout>
                            <Flyout x:Name="WebDavFlyout" Placement="Bottom">
                                <ScrollViewer MaxHeight="400" Width="300"
                                             HorizontalScrollBarVisibility="Disabled"
                                             VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="WebDavPanel" Spacing="2">
                                        <StackPanel.Resources>
                                            <ResourceDictionary>
                                                <ResourceDictionary.ThemeDictionaries>
                                                    <ResourceDictionary x:Key="Light">
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15000000"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#25000000"/>
                                                        <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#15000000"/>
                                                        <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="#25000000"/>
                                                    </ResourceDictionary>
                                                    <ResourceDictionary x:Key="Dark">
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15FFFFFF"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#25FFFFFF"/>
                                                        <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#15FFFFFF"/>
                                                        <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="#25FFFFFF"/>
                                                    </ResourceDictionary>
                                                </ResourceDictionary.ThemeDictionaries>
                                            </ResourceDictionary>
                                        </StackPanel.Resources>
                                        <Button x:Name="AddWebDavButton" Content="➕ webdav 서버 추가"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Background="Transparent" BorderThickness="0">
                                            <Button.Resources>
                                                <ResourceDictionary>
                                                    <ResourceDictionary.ThemeDictionaries>
                                                        <ResourceDictionary x:Key="Light">
                                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15000000"/>
                                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#25000000"/>
                                                        </ResourceDictionary>
                                                        <ResourceDictionary x:Key="Dark">
                                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15FFFFFF"/>
                                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#25FFFFFF"/>
                                                        </ResourceDictionary>
                                                    </ResourceDictionary.ThemeDictionaries>
                                                </ResourceDictionary>
                                            </Button.Resources>
                                        </Button>
                                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>
                                        <!-- Saved WebDAV servers will be added dynamically -->
                                    </StackPanel>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

                <!-- Current Path -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="CurrentPathText" Grid.Row="0" 
                               Text="폴더를 선택하세요" 
                               Padding="12,8" FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- File List -->
                    <ListView x:Name="FileListView" Grid.Row="1" 
                              SelectionMode="Single"
                              IsItemClickEnabled="True">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,6" ColumnSpacing="8" Background="Transparent"
                                      ToolTipService.ToolTip="{Binding Name}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <FontIcon Glyph="{Binding Icon}" FontSize="14"
                                              Foreground="{Binding IconColor}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                               VerticalAlignment="Center"
                                               FontFamily="{ThemeResource ContentControlThemeFontFamily}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <GridView x:Name="FileGridView" Grid.Row="1"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              Visibility="Collapsed"
                              Padding="4">
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding ThumbnailItemWidth}" Height="{Binding ThumbnailItemHeight}" Padding="4" Background="Transparent" CornerRadius="4"
                                      ToolTipService.ToolTip="{Binding Name}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Grid Grid.Row="0">
                                        <FontIcon Glyph="{Binding Icon}" FontSize="{Binding ThumbnailIconSize}" Foreground="{Binding IconColor}" 
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Visibility="{Binding IconVisibility}" />
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               MaxWidth="{Binding ThumbnailImageSize}" MaxHeight="{Binding ThumbnailImageSize}"
                                               Visibility="{Binding ImageThumbnailVisibility}"/>
                                        <Grid Width="{Binding ThumbnailImageSize}" Height="{Binding ThumbnailImageSize}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Visibility="{Binding FolderThumbnailVisibility}">
                                            <Border Width="{Binding FolderThumbnailTabWidth}"
                                                    Height="{Binding FolderThumbnailTabHeight}"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="{Binding FolderThumbnailTabMargin}"
                                                    Background="#DAA520"
                                                    CornerRadius="4,4,0,0"/>
                                            <Border Width="{Binding FolderThumbnailBodyWidth}"
                                                    Height="{Binding FolderThumbnailBodyHeight}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Bottom"
                                                    Background="#FFD700"
                                                    BorderBrush="#B8860B"
                                                    BorderThickness="1"
                                                    CornerRadius="5"/>
                                            <Border Width="{Binding FolderThumbnailInsetWidth}"
                                                    Height="{Binding FolderThumbnailInsetHeight}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Bottom"
                                                    Margin="0,0,0,8"
                                                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                                    BorderBrush="#AA8A6110"
                                                    BorderThickness="1"
                                                    CornerRadius="3">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                            </Border>
                                            <Border Width="{Binding FolderThumbnailBodyWidth}"
                                                    Height="{Binding FolderThumbnailBodyHeight}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Bottom"
                                                    Background="Transparent"
                                                    BorderBrush="#AA8A6110"
                                                    BorderThickness="1"
                                                    CornerRadius="5"/>
                                        </Grid>
                                    </Grid>

                                    <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="11" 
                                               FontFamily="{ThemeResource ContentControlThemeFontFamily}"
                                               TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" 
                                               MaxLines="2" TextAlignment="Center" Margin="0,4,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Grid>
            </Grid>

</UserControl>

