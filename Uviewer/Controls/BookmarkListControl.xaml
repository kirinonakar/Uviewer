<UserControl
    x:Class="Uviewer.Controls.BookmarkListControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Uviewer.Controls"
    xmlns:models="using:Uviewer.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:ProgressToWidthConverter x:Key="ProgressToWidthConverter"/>
    </UserControl.Resources>

    <Grid>
        <ListView x:Name="BookmarkListView" 
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  Padding="0"
                  ItemClick="BookmarkListView_ItemClick">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,1"/>
                    <Setter Property="MinHeight" Value="40"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:BookmarkViewModel">
                    <Grid ToolTipService.ToolTip="{x:Bind Tooltip}" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Content Area -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="12,4,8,4">
                            <!-- Name Row -->
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE774;" 
                                          FontSize="12" 
                                          Margin="0,1,6,0" 
                                          Foreground="CornflowerBlue"
                                          Visibility="{x:Bind IsWebDav, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <TextBlock Text="{x:Bind Name}" 
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           FontSize="13"
                                           x:Name="NameTextBlock"
                                           Loaded="NameTextBlock_Loaded"/>
                                <TextBlock Text="{x:Bind DisplayPosition}" 
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="Gray"/>
                            </StackPanel>

                            <!-- Progress Row -->
                            <Grid Margin="0,3,0,0" Visibility="{x:Bind IsNotFolder, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Grid x:Name="ProgressBarGrid" HorizontalAlignment="Left" MaxWidth="280" Height="2">
                                    <Border Background="Transparent" CornerRadius="1" HorizontalAlignment="Stretch"/>
                                    <Border Background="CornflowerBlue" 
                                            CornerRadius="1" 
                                            HorizontalAlignment="Left"
                                            Width="{x:Bind Progress, Converter={StaticResource ProgressToWidthConverter}, ConverterParameter=280}"/>
                                </Grid>

                                <TextBlock Grid.Column="1" 
                                           Text="{x:Bind ProgressString}" 
                                           FontSize="10" 
                                           Foreground="Gray"
                                           Margin="6,-2,0,0" 
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- Pin Button -->
                        <Button Grid.Column="1" 
                                Width="32" Height="32" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                Visibility="{x:Bind IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Click="PinButton_Click">
                            <FontIcon Glyph="{x:Bind PinIcon}" 
                                      FontSize="14"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Foreground="{x:Bind PinColor}"/>
                        </Button>

                        <!-- Delete Button -->
                        <Button Grid.Column="2" 
                                Width="32" Height="32" Padding="0"
                                Background="Transparent" BorderThickness="0" Margin="0,0,4,0"
                                Click="DeleteButton_Click">
                            <FontIcon Glyph="&#xE711;" FontSize="14"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <!-- Empty State Message -->
        <TextBlock x:Name="EmptyTextBlock" 
                   Foreground="Gray" 
                   Margin="12,8,12,8" 
                   FontSize="13"/>
    </Grid>
</UserControl>
