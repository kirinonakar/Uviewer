<ContentDialog
    x:Class="Uviewer.Dialogs.GoToLineDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Uviewer.Dialogs"
    xmlns:common="using:Uviewer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="{x:Bind DialogTitle, Mode=OneWay}"
    PrimaryButtonText="{x:Bind common:Strings.DialogPrimary}"
    CloseButtonText="{x:Bind common:Strings.DialogClose}"
    DefaultButton="Primary">

    <StackPanel Width="300" Spacing="8">
        <TextBox x:Name="InputBox"
                 InputScope="Number"
                 PlaceholderText="{x:Bind Placeholder, Mode=OneWay}"
                 Text="{x:Bind CurrentLineText, Mode=TwoWay}"/>
    </StackPanel>
</ContentDialog>
