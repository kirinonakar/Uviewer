<ContentDialog
    x:Class="Uviewer.Dialogs.FontPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Uviewer.Dialogs"
    xmlns:common="using:Uviewer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="{x:Bind DialogTitle, Mode=OneWay}"
    PrimaryButtonText="{x:Bind common:Strings.DialogPrimary}"
    CloseButtonText="{x:Bind common:Strings.DialogClose}"
    DefaultButton="Primary">

    <StackPanel Width="310" PreviewKeyDown="StackPanel_PreviewKeyDown">
        <AutoSuggestBox x:Name="SearchBox"
                        PlaceholderText="{x:Bind common:Strings.FontSearchPlaceholder}"
                        QueryIcon="Find"
                        Margin="0,0,0,10"
                        Width="300"
                        TextChanged="SearchBox_TextChanged"/>
        
        <ListView x:Name="FontListView"
                  SelectionMode="Single"
                  MaxHeight="400"
                  Width="300"
                  BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                  BorderThickness="1">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <TextBlock Text="{x:Bind}" 
                               FontFamily="{x:Bind}" 
                               FontSize="16" 
                               VerticalAlignment="Center" 
                               Padding="4"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
